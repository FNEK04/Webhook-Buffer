# Server Configuration
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
APP_ENV=development

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# PostgreSQL Configuration
POSTGRES_CONN_STRING=postgres://webhook:webhook123@localhost:5432/webhook_buffer?sslmode=disable
POSTGRES_PASSWORD=webhook123

# 1C Configuration
ONEC_BASE_URL=http://localhost:8081
ONEC_USERNAME=admin
ONEC_PASSWORD=password
ONEC_TIMEOUT=30s

# Worker Configuration
WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL=1s
WORKER_MAX_RETRIES=5
WORKER_CACHE_TTL=5m
WORKER_QUEUE_MAX_SIZE=100000

# Security
API_KEY=
RATE_LIMIT_RPS=1000
RATE_LIMIT_BURST=2000
